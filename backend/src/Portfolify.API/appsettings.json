{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=portfolify;Username=postgres;Password=postgres"
  },
  "Cors": {
    "AllowedOrigins": "http://localhost:3002"
  },
  "Jwt": {
    "Issuer": "Portfolify",
    "Audience": "PortfolifyUsers",
    "Key": "ThisIsASuperSecretKeyForJwtTokenGeneration_DoNotUseInProduction_2024!",
    "ExpiryMinutes": 1440
  },
  "Serilog": {
    "Using": ["Serilog.Sinks.Console"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  },
  "AllowedHosts": "*"
}
