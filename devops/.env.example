# Huawei Cloud RDS PostgreSQL connection string
# Guvenli baglanti icin sona "SSL Mode=Require;" ekleyebilirsin.
DB_CONNECTION_STRING=Host=<rds-host>;Port=5432;Database=portfolify;Username=<user>;Password=<password>

# JWT ayarlari
JWT_ISSUER=Portfolify
JWT_AUDIENCE=PortfolifyUsers
JWT_KEY=change-me-to-a-strong-secret-key
JWT_EXPIRY_MINUTES=1440

# Frontend origin'leri (CORS) - virgulle ayrilmis
CORS_ALLOWED_ORIGINS=http://213.250.148.96:3000
